{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command",
            "if": "Bash(git commit *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-commit.sh" },
          { "type": "command",
            "if": "Bash(gh pr create *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-pr.sh" }
        ]
      }
    ]
  }
}
