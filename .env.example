# Postgres connection string. For Neon, use the *pooled* connection string
# for application runtime, and the *unpooled* (direct) one for migrations.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cesium Ion access token (get a free one at https://cesium.com/ion/tokens).
# Required for Bing aerial imagery and 3D terrain. NEXT_PUBLIC_ prefix
# is required because Ion auth happens in the browser.
NEXT_PUBLIC_CESIUM_ION_TOKEN=
